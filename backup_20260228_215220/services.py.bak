from django.core.cache import cache
from django.conf import settings
from .adapters import DeepSeekSmartReplyAdapter
import logging

logger = logging.getLogger(__name__)

class SmartReplyService:
    def __init__(self):
        self.adapter = GeminiSmartReplyAdapter()
    
    async def get_suggestions(self, room_id, user_id, conversation_history):
        history_hash = hash("".join(conversation_history[-4:]))
        cache_key = f'smart_reply_{room_id}_{user_id}_{history_hash}'
        
        cached = cache.get(cache_key)
        if cached:
            return cached
        
        if len(conversation_history) < settings.SMART_REPLY['MIN_MESSAGES_FOR_CONTEXT']:
            return []
        
        rate_key = f'smart_reply_rate_{user_id}'
        rate_count = cache.get(rate_key, 0)
        if rate_count > settings.SMART_REPLY['RATE_LIMIT']:
            return []
        cache.set(rate_key, rate_count + 1, 60)
        
        try:
            suggestions = await self.adapter.generate_suggestions(
                conversation_history,
                max_suggestions=settings.SMART_REPLY['MAX_SUGGESTIONS']
            )
            
            if suggestions:
                cache.set(cache_key, suggestions, settings.SMART_REPLY['CACHE_TTL'])
            
            return suggestions
            
        except Exception as e:
            logger.error(f"Smart reply generation failed: {e}")
            return []


